# Storage CDN hostname (thumbnails signing only — video is Stream HLS).
NEXT_PUBLIC_BUNNY_CDN_URL=https://filmflik.b-cdn.net

# Pull Zone → Security → URL Token Authentication Key (server-only) — thumbnails
BUNNY_TOKEN_KEY=
BUNNY_TOKEN_AUTH_MODE=sha256
BUNNY_TOKEN_TTL=7200

# Bunny Storage API (catalog.json + thumbnails only) — server-only
# Zone NAME only (e.g. filmflik) — not a URL
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_KEY=
# Hostname only (e.g. sg.storage.bunnycdn.com)
BUNNY_STORAGE_REGION=storage.bunnycdn.com

# Bunny Stream HLS (required for all playback)
# Stream → Library → API
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
# Stream CDN hostname, e.g. https://vz-xxxxxxxx.b-cdn.net
BUNNY_STREAM_CDN_URL=
# REQUIRED for anti-hotlink: Stream → Security → Token Authentication (separate key, NOT the API key).
BUNNY_STREAM_TOKEN_KEY=
# Short-lived CDN directory tokens for HLS segments (seconds). Default 900 (15 min).
BUNNY_STREAM_TOKEN_TTL=900

# Playback gate (httpOnly cookie + referer allowlist on /api/media)
PLAYBACK_SECRET=
# PLAYBACK_SESSION_TTL=7200
# PLAYBACK_ALLOWED_ORIGINS=

# Admin release panel
ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=

# Supabase (user accounts, watch progress, watchlist)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — webhooks / admin grants later (optional for MVP)
# SUPABASE_SERVICE_ROLE_KEY=
# Login required to watch (default: on when Supabase URL+anon key are set)
# REQUIRE_AUTH_TO_WATCH=true
# Enforce active/trialing subscription (default: off)
# REQUIRE_SUBSCRIPTION=false
